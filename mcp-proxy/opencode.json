{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "files": {
      "type": "local",
      "command": [
        "/tmp/obsigna-sbx/bin/obsigna-mcp",
        "--socket", "/tmp/obsigna.sock",
        "--name", "files",
        "npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/agent/workspace/work"
      ],
      "environment": {
        "AGENTRECEIPTS_SOCKET": "/tmp/obsigna.sock"
      }
    }
  },
  "provider": {
    "openai-compatible": {
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "devstral-demo:latest": {
          "name": "Devstral Demo (32K ctx)",
          "tool_call": true
        },
        "qwen2.5-coder:32b": {
          "name": "Qwen 2.5 Coder 32B",
          "tool_call": true
        }
      }
    }
  },
  "model": "openai-compatible/devstral-demo:latest"
}
